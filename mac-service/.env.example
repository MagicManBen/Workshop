# Workshop Label Service — environment configuration example.
# Copy this file to `.env` and adjust. Never commit the real .env.
#
# Section 1 has NO Supabase dependency, so no secrets are required yet.
# These values are optional overrides for local development.

# Host/port the local control UI binds to. Keep 127.0.0.1 for localhost-only.
HOST=127.0.0.1
PORT=8765

# --- Supabase (Section 3) ---------------------------------------------
# The service-role key is used SERVER-SIDE ONLY by this always-on service to
# consume the print-job queue. It must never be placed in browser code.
# Copy this file to `.env` and fill in the real values (never commit .env).
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_SCHEMA=workshop

# Identity + timing for the print-queue worker.
SERVICE_NAME=mac-print-service
POLL_INTERVAL_SECONDS=3
HEARTBEAT_INTERVAL_SECONDS=15
