# -----------------------------------------------------------------------------
# Workshop Label Service — example environment file
#
# Copy to `.env` and edit if you need to override defaults. No secrets are
# required for Section 1. NEVER commit a real .env file.
# -----------------------------------------------------------------------------

# Override where runtime data (config.toml, history.db, logs/) is stored.
# Defaults to a `data/` folder next to the app / exe.
# WLS_DATA_DIR=C:\ProgramData\WorkshopLabelService

# Override the UI bind host/port (also configurable in config.toml).
# WLS_HOST=127.0.0.1
# WLS_PORT=8765

# Set logging verbosity: DEBUG, INFO, WARNING, ERROR.
# WLS_LOG_LEVEL=INFO
